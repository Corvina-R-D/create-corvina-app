{
  "name": "[| .Name |]-service",
  "version": "1.0.0",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "env-cmd nest start",
    "start:dev": "env-cmd nest start --watch",
    "start:debug": "env-cmd nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "env-cmd --use-shell \"START_FEATURES=migrator.up,quit nest start && jest\"",
    "test:watch": "env-cmd --use-shell \"START_FEATURES=migrator.up,quit nest start && jest --watch\"",
    "test:cov": "env-cmd --use-shell \"START_FEATURES=migrator.up,quit nest start && jest --coverage\"",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/swagger": "^11.2.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "match-url-wildcard": "^0.0.4",
    "pg": "^8.10.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.0",
    "redis": "^4.6.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.2.0",
    "semver": "^7.7.4",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/supertest": "^7",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "env-cmd": "^11.0.0",
    "eslint": "^8.33.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^17.0.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "29.7.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.20",
    "supertest": "^7.2.2",
    "ts-jest": "29.1.2",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
